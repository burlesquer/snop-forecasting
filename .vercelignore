# Only the dashboard/ folder needs to ship to Vercel.
# Everything else (ML pipeline, raw M5 data, model artifacts, tools, tests,
# planning docs) stays out of the upload — they would blow past the 100MB
# limit and aren't needed by the Next.js app at runtime.

ml/
tools/
tests/
data/
models/
.venv/
venv/
.kaggle/
.omc/
.gstack/
.claude/
.cursor/
.idea/
.vscode/

